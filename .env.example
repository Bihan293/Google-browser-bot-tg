# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# Public HTTPS URL where Telegram will POST updates
# e.g. https://your-domain.tld
WEBHOOK_URL=https://your-domain.tld

# Path on the server that handles updates (must match WEBHOOK_URL)
WEBHOOK_PATH=/tg/webhook

# Port the HTTP server listens on
PORT=8080

# Optional secret token for Telegram webhook verification
WEBHOOK_SECRET=

# Enable verbose Telegram API debug logs (true/false)
DEBUG=false
